#!/usr/bin/env python3
"""redjob — дежурный оператор парка launchd/cron джоб (Фаза 1: read-only).

Команды:
  redjob list [--md]      карта парка (timeline / persistent / сводка)
  redjob doctor [--quiet] read-only аудит (класс тихих поломок + коллизии)
  redjob validate         проверить jobs.yaml по схеме
  redjob seed [--write]   пересобрать реестр из живых plist (dry-run без --write)
  redjob add <spec.json> [--generate]   советник размещения (Ф2) + генерация plist
  redjob vault-audit      развёртка «кто может открыть окно 1Password-сейфа»
  redjob version

Фаза 1 НЕ лечит и НЕ трогает launchd — только читает и диагностирует.
Фаза 2 (`add`) советует и генерирует plist, но НЕ устанавливает — сажает человек.
"""
import os
import sys

LIB = os.path.join(os.path.dirname(os.path.dirname(os.path.abspath(__file__))), "lib")
sys.path.insert(0, LIB)

USAGE = __doc__


def main():
    argv = sys.argv[1:]
    if not argv or argv[0] in ("-h", "--help", "help"):
        print(USAGE)
        return 0
    cmd, rest = argv[0], argv[1:]

    if cmd == "list":
        import list_cmd
        return list_cmd.main(rest)
    if cmd == "doctor":
        import doctor
        return doctor.main(rest)
    if cmd == "validate":
        import registry
        data = registry.load()
        errs = registry.validate(data)
        if errs:
            print("INVALID:\n  " + "\n  ".join(errs))
            return 1
        print(f"✓ jobs.yaml валиден ({len(data.get('jobs', []))} джоб, schema v{data['schema_version']})")
        return 0
    if cmd == "seed":
        import seed
        import registry
        data = seed.build()
        errs = registry.validate(data)
        if errs:
            print("SEED INVALID:\n  " + "\n  ".join(errs), file=sys.stderr)
            return 1
        if "--write" in rest:
            registry.atomic_write(data)
            print(f"✓ jobs.yaml записан: {len(data['jobs'])} джоб")
        else:
            print(registry.dump_str(data))
            print(f"\n# dry-run: {len(data['jobs'])} джоб (--write чтобы записать)", file=sys.stderr)
        return 0
    if cmd == "add":
        import add_cmd
        return add_cmd.main(rest)
    if cmd == "vault-audit":
        import vault_audit
        return vault_audit.main(rest)
    if cmd == "version":
        import registry
        print(f"redjob Фаза 1+2 · schema v{registry.SCHEMA_VERSION}")
        return 0

    print(f"неизвестная команда: {cmd}\n\n{USAGE}", file=sys.stderr)
    return 2


if __name__ == "__main__":
    sys.exit(main())
